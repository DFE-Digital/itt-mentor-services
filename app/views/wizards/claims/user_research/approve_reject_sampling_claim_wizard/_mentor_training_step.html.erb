<% contextual_text = t(".caption", claim_reference: @wizard.claim_reference) %>
<% content_for :page_title, title_with_error_prefix(t(".page_title", contextual_text:, mentor_full_name: current_step.mentor_full_name), error: current_step.errors.any?) %>

<%= form_for(current_step, url: current_step_path, method: :put) do |f| %>
  <%= f.govuk_error_summary %>

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <span class="govuk-caption-l"><%= contextual_text %></span>
      <h1 class="govuk-heading-l"><%= t(".heading", mentor_full_name: current_step.mentor_full_name, mentor_trn: current_step.mentor_trn) %></h1>

      <div class="govuk-form-group">
        <%= f.govuk_number_field(
          :hours_completed,
          width: 2,
          label: { text: t(".label"), size: "m" },
          hint: { text: t(".hint", max_hours: current_step.max_hours) }
        ) %>
      </div>

      <% if @wizard.action == "reject" %>
        <%= f.govuk_text_area(
          :reason_not_assured,
          label: { text: t(".reason_label"), size: "m" },
          hint: { text: t(".reason_hint") },
          rows: 5
        ) %>
      <% end %>

      <%= f.govuk_submit t(".continue") %>
    </div>
  </div>
<% end %>
