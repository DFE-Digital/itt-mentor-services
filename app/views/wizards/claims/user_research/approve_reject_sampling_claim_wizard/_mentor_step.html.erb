<% contextual_text = t(".caption", claim_reference: @wizard.claim_reference) %>
<% content_for :page_title, title_with_error_prefix(t(".page_title", contextual_text:), error: current_step.errors.any?) %>

<%= form_for(current_step, url: current_step_path, method: :put) do |f| %>
  <%= f.govuk_error_summary %>

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <span class="govuk-caption-l"><%= contextual_text %></span>

      <%= f.govuk_collection_check_boxes(
        :mentor_ids,
        current_step.mentors,
        :id, :full_name, :trn,
        legend: {
          size: "l",
          text: t(".heading"),
          tag: "h1",
        }
      ) %>

      <%= f.govuk_submit t(".continue") %>
    </div>
  </div>
<% end %>
